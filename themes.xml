<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AiChat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/accent_dark</item>
        <item name="android:windowBackground">@color/chat_background</item>
    </style>

    <style name="Theme.AiChat.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/accent</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_bot_avatar</item>
        <item name="postSplashScreenTheme">@style/Theme.AiChat</item>
    </style>

</resources>
